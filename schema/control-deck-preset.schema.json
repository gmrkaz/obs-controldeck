{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gmrkaz/obs-controldeck/schema/control-deck-preset.schema.json",
  "title": "OBS ControlDeck Preset",
  "type": "object",
  "additionalProperties": true,
  "required": ["profileName", "version"],
  "properties": {
    "profileName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mic": { "type": "string" },
        "desktopAudio": { "type": "string" },
        "camera": { "type": "string" }
      }
    },
    "scenes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "panic": { "type": "string" },
        "intro": { "type": "string" },
        "main": { "type": "string" }
      }
    },
    "recordingGuard": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "checkMicrophone": { "type": "boolean" },
        "checkDesktopAudio": { "type": "boolean" },
        "checkCamera": { "type": "boolean" }
      }
    },
    "autoIntro": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "delaySeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        }
      }
    },
    "markers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "soundpad": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "file", "volume"],
        "properties": {
          "title": { "type": "string" },
          "file": { "type": "string" },
          "volume": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    }
  }
}
